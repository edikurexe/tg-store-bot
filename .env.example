# Environment Variables
# Copy this file to .env and fill in your values

# Telegram Bot Token (from @BotFather)
TG_STORE_TOKEN=your_bot_token_here

# Admin Telegram User IDs (comma separated)
ADMIN_IDS=123456789

# Store Name
STORE_NAME=🏪 My Digital Store

# Midtrans (optional)
MIDTRANS_SERVER_KEY=
MIDTRANS_PRODUCTION=false

# Payment info for manual mode
PAYMENT_INFO=Transfer ke: Bank BCA 1234567890 a.n. Nama
